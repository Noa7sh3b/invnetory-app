# Mini Inventory Management System - Environment Configuration
# Rename this file to .env and modify as needed

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name (displayed in browser tab)
APP_NAME=Mini Inventory

# =============================================================================
# PAGINATION SETTINGS
# =============================================================================

# Number of items per page in lists
PAGE_SIZE=8

# Maximum number of items to load in memory (for performance)
MAX_LIST_LOAD=100
